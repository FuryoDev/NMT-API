{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Translation": {
    "NllbOnnx": {
      "ModelName": "facebook/nllb-200-distilled-600M",
      "Device": "cpu",
      "ModelPath": "models/nllb/model.onnx",
      "EnableOnnxRuntime": false,
      "MaxInputTokens": 512,
      "DefaultMaxNewTokens": 256,
      "DefaultNumBeams": 4,
      "NoRepeatNgramSize": 3,
      "RepetitionPenalty": 1.15
    }
  },
  "AllowedHosts": "*"
}
