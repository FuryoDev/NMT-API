{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Translation": {
    "PythonBackend": {
      "BaseUrl": "http://127.0.0.1:8000",
      "TimeoutSeconds": 120,
      "StartupHealthCheckTimeoutSeconds": 10,
      "FallbackModelName": "facebook/nllb-200-distilled-600M",
      "FallbackDevice": "python-backend",
      "AutoStartInDevelopment": false,
      "AutoStartWorkingDirectory": "../python projet",
      "AutoStartCommand": "python",
      "AutoStartArguments": "-m uvicorn api:app --host 127.0.0.1 --port 8000",
      "AutoStartWarmupDelaySeconds": 2
    }
  },
  "AllowedHosts": "*"
}
