{
  "openapi": "3.1.1",
  "info": {
    "title": "NMT API (Development - OnPrem)",
    "description": "Neural machine translation API (text, files, and SRT subtitles).",
    "contact": {
      "name": "Solutions et Produits",
      "email": "SolEtPro@rtbf.be"
    },
    "version": "v1.0.1"
  },
  "servers": [
    {
      "url": "http://localhost:777"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": [
          "Translation"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/Debug/Headers": {
      "get": {
        "tags": [
          "NMT-api"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/Debug/Proxy": {
      "get": {
        "tags": [
          "NMT-api"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnonymousTypeOfstringAndstringAndstring"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "Translation"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/translate": {
      "post": {
        "tags": [
          "Translation"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TranslateRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/TranslateRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/TranslateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/TranslateResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranslateResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranslateResponse"
                }
              }
            }
          }
        }
      }
    },
    "/translate/file": {
      "post": {
        "tags": [
          "Translation"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "$ref": "#/components/schemas/IFormFile"
                  },
                  "sourceLanguage": {
                    "type": "string"
                  },
                  "targetLanguage": {
                    "type": "string"
                  },
                  "maxNewTokens": {
                    "pattern": "^-?(?:0|[1-9]\\d*)$",
                    "type": [
                      "integer",
                      "string"
                    ],
                    "format": "int32"
                  },
                  "numBeams": {
                    "pattern": "^-?(?:0|[1-9]\\d*)$",
                    "type": [
                      "integer",
                      "string"
                    ],
                    "format": "int32"
                  },
                  "preprocess": {
                    "type": "boolean"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": { }
            }
          }
        }
      }
    },
    "/translate/file/json": {
      "post": {
        "tags": [
          "Translation"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "$ref": "#/components/schemas/IFormFile"
                  },
                  "sourceLanguage": {
                    "type": "string"
                  },
                  "targetLanguage": {
                    "type": "string"
                  },
                  "maxNewTokens": {
                    "pattern": "^-?(?:0|[1-9]\\d*)$",
                    "type": [
                      "integer",
                      "string"
                    ],
                    "format": "int32"
                  },
                  "numBeams": {
                    "pattern": "^-?(?:0|[1-9]\\d*)$",
                    "type": [
                      "integer",
                      "string"
                    ],
                    "format": "int32"
                  },
                  "preprocess": {
                    "type": "boolean"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/TranslateResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranslateResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranslateResponse"
                }
              }
            }
          }
        }
      }
    },
    "/translate/srt": {
      "post": {
        "tags": [
          "Translation"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "$ref": "#/components/schemas/IFormFile"
                  },
                  "sourceLanguage": {
                    "type": "string"
                  },
                  "targetLanguage": {
                    "type": "string"
                  },
                  "maxNewTokens": {
                    "pattern": "^-?(?:0|[1-9]\\d*)$",
                    "type": [
                      "integer",
                      "string"
                    ],
                    "format": "int32"
                  },
                  "numBeams": {
                    "pattern": "^-?(?:0|[1-9]\\d*)$",
                    "type": [
                      "integer",
                      "string"
                    ],
                    "format": "int32"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": { }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AnonymousTypeOfstringAndstringAndstring": {
        "required": [
          "clientIP",
          "scheme",
          "protocol"
        ],
        "type": "object",
        "properties": {
          "clientIP": {
            "type": [
              "null",
              "string"
            ]
          },
          "scheme": {
            "type": [
              "null",
              "string"
            ]
          },
          "protocol": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "device": {
            "type": "string"
          },
          "startupMs": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "model": {
            "type": "string"
          }
        }
      },
      "IFormFile": {
        "type": "string",
        "format": "binary"
      },
      "TranslateRequest": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "sourceLanguage": {
            "type": "string"
          },
          "targetLanguage": {
            "type": "string"
          },
          "maxNewTokens": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "numBeams": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "preprocess": {
            "type": "boolean"
          }
        }
      },
      "TranslateResponse": {
        "type": "object",
        "properties": {
          "translatedText": {
            "type": "string"
          },
          "device": {
            "type": "string"
          },
          "durationMs": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "preprocessing": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "NMT-api"
    },
    {
      "name": "Translation"
    }
  ]
}